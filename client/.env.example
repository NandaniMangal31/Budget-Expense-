# ============================================================
# SMART BUDGET ANALYZER - FRONTEND ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this to .env.local and fill in your actual values
#
# SECURITY WARNING:
# - NEVER store sensitive API keys here
# - Use environment variables for secrets on backend only
# - Frontend code is visible in browser
# ============================================================

# 🔗 BACKEND API CONFIGURATION
# This URL tells the frontend where to send API requests
#
# DEVELOPMENT (local backend):
# VITE_API_URL=http://localhost:5000/api
#
# PRODUCTION (Render backend):
# VITE_API_URL=https://smart-spending-backend.onrender.com/api
#
# NOTE: Update this URL after deploying backend to Render

VITE_API_URL=http://localhost:5000/api

# Backward-compatible alias (for older code)
VITE_API_BASE_URL=http://localhost:5000/api

# ============================================================
# BUILD & DEPLOYMENT SETTINGS
# ============================================================

# Vite mode (affects build optimization)
# development | production (auto-detected, usually don't change)
VITE_ENV_MODE=production

# ============================================================
# DEPLOYMENT INSTRUCTIONS
# ============================================================

# For Vercel Deployment:
# 1. Push code to GitHub
# 2. Connect repo to Vercel dashboard
# 3. Set environment variable:
#    VITE_API_URL=https://smart-spending-backend.onrender.com/api
# 4. Deploy (Vercel auto-deploys on git push)
#
# IMPORTANT: Update VITE_API_URL to match your backend URL
#            after deploying backend to Render!

# ============================================================
# TROUBLESHOOTING
# ============================================================

# If you see: "CORS error" or "Failed to fetch"
# 1. Check VITE_API_URL is correct
# 2. Verify backend is running
# 3. Check backend CORS configuration in server.js
# 4. For production, ensure both URLs use https://
#
# If API calls work locally but not in production:
# 1. Check VITE_API_URL in production environment
# 2. Verify Render backend is deployed and running
# 3. Check Render logs for errors
#
# Common URLs:
# Local:       http://localhost:5000/api
# Render Prod: https://smart-spending-backend.onrender.com/api
# Vercel Prod: https://smart-spending-frontend.vercel.app

# ============================================================
# NO SENSITIVE KEYS IN THIS FILE!
# ============================================================
# API keys, tokens, passwords must NEVER be in frontend .env
# Always keep secrets on the backend only
# Frontend code is visible to all users in browser DevTools

