# Frontend Environment Variables Template
# Copy this to .env.local and fill in your actual values

# API Configuration
# Preferred API URL variable
VITE_API_URL=http://localhost:5000/api
# Backward-compatible alias
VITE_API_BASE_URL=http://localhost:5000/api

# Production (Vercel): set this to your Render backend URL
# VITE_API_URL=https://smart-spending-backend.onrender.com/api
# NEVER store sensitive keys like API keys in frontend .env
# Always keep secrets on the backend only
