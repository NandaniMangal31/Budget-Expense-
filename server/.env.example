# ============================================================
# SMART BUDGET ANALYZER - BACKEND ENVIRONMENT CONFIGURATION
# ============================================================
# This file contains all required environment variables.
# Copy to .env and fill in your actual values.
#
# SECURITY WARNING:
# - Never commit .env to git (already in .gitignore)
# - Use strong, unique secrets for production
# - Keep JWT_SECRET and API keys confidential
# ============================================================

# 🌐 SERVER CONFIGURATION
# Default: 5000 (leave empty on Render for auto-assignment)
# Used in: server.js
PORT=5000

# 🚀 DEPLOYMENT ENVIRONMENT
# Values: development | production
# Used in: server.js (CORS, error handling)
NODE_ENV=production

# ============================================================
# 🗄️ DATABASE CONFIGURATION
# ============================================================

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name
# Get from: MongoDB Atlas > Cluster > Connect > Connection String
# CRITICAL: Add Render IP or 0.0.0.0/0 to IP Whitelist
# Used in: config/db.js
MONGO_URI=mongodb+srv://user:password@smart-budget.mongodb.net/smart_spending

# ============================================================
# 🔐 AUTHENTICATION & SECURITY
# ============================================================

# JWT Secret for token signing
# Min 32 characters, use strong random string
# Generate: openssl rand -hex 32 (Linux/Mac)
#           python -c "import secrets; print(secrets.token_hex(32))" (Windows/Mac)
# CRITICAL: Different for dev/prod, never share publicly
# Used in: middleware/authMiddleware.js, controllers/authController.js
JWT_SECRET=your_secure_jwt_secret_here_minimum_32_characters_long

# ============================================================
# 🤖 AI & OCR CONFIGURATION
# ============================================================

# Google Gemini API Key (for receipt OCR & AI vision)
# Free tier: 60 requests/minute
# Get from: https://aistudio.google.com/app/apikey
# Purpose: Scans receipts, extracts transactions, categorizes expenses
# Fallback: If unavailable, uses local Tesseract OCR
# Used in: controllers/expenseController.js, services/openaiService.js
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (for advanced expense categorization)
# Optional but recommended for better AI categorization
# Get from: https://platform.openai.com/api-keys
# Used in: services/openaiService.js
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# 📧 EMAIL CONFIGURATION (for budget alerts)
# ============================================================

# Gmail App-Specific Password (NOT your Gmail password!)
# IMPORTANT: Must enable 2-factor authentication first
# Generate at: https://myaccount.google.com/apppasswords
# Steps:
#   1. Enable 2-factor authentication in Google Account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select "Mail" and "Windows Computer" (or other)
#   4. Copy the 16-character password shown
# Used in: utils/sendemail.js
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password_here

# ============================================================
# 🚀 DEPLOYMENT SETTINGS (for Render)
# ============================================================

# Render deployment URL (set after deployment)
# Example: https://smart-spending-backend.onrender.com
# Used for CORS configuration and internal references
RENDER_URL=https://smart-spending-backend.onrender.com

# ============================================================
# 📝 NOTES & TROUBLESHOOTING
# ============================================================

# 1. CORS Configuration (in server.js):
#    - Allows: Vercel frontend, localhost:3000, localhost:5173
#    - Update if using different frontend URL
#
# 2. File Upload Limits:
#    - Maximum file size: 25MB
#    - Supported types: JPG, PNG, PDF, XLSX, CSV, TXT, RTF, DOCX
#
# 3. Render Deployment:
#    - Copy these variables into Render Dashboard
#    - Build command: npm install
#    - Start command: npm start
#    - Don't expose .env file in code
#
# 4. MongoDB Whitelist:
#    - For Render: Add 0.0.0.0/0 or specific Render IPs
#    - For local dev: Add 127.0.0.1
#
# 5. Gemini Quota:
#    - Free tier: 60 requests/minute
#    - Premium: Higher limits available
#    - Fallback: Local OCR works if quota exceeded

# ============================================================
# DEPLOYMENT CHECKLIST
# ============================================================
# ☑ All required variables filled (no "your_*_here" placeholders)
# ☑ MongoDB URI tested and verified
# ☑ Gemini API Key valid and quota available
# ☑ JWT_SECRET is strong (32+ chars, random)
# ☑ Gmail app password (not regular Gmail password)
# ☑ Variables securely stored (not in git)
# ☑ Render environment variables configured
# ☑ MongoDB IP whitelist includes Render/local IPs
# ☑ Frontend VITE_API_URL updated with backend URL


