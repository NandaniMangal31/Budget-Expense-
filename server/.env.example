# Backend Environment Variables Template
# Copy this to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smart-spending-lock

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# Gemini API (Google Generative AI)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API (Optional - if using OpenAI features)
OPENAI_API_KEY=sk-your_openai_key_here

# Email Configuration (Optional - if using email notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_SERVICE=gmail

# Note: NEVER commit the .env file to GitHub
# Always use .env.example as a template
